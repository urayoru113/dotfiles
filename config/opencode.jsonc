{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemma-4-31b-it",
  "instructions": [
    "~/.dotfiles/ai/rules/AGENTS.md"
  ],
  "lsp": true,
  "provider": {
    "openrouter": {
      "models": {
        "free": {},
        "owl-alpha": {}
      },
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    },
    "google": {
      "models": {
        "gemma-4-26b-a4b-it": {},
        "gemma-4-31b-it": {}
      },
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      }
    },
    "groq": {
      "models": {},
      "options": {
        "apiKey": "{env:GROQ_API_KEY}"
      }
    }
  }
}