{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemma-4-31b-it",
  "provider": {
    "openrouter": {
      "models": {},
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    },
    "google": {
      "models": {
        "gemma-4-31b-it": {}
      },
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      }
    },
    "groq": {
      "models": {},
      "options": {
        "apiKey": "{env:GROQ_API_KEY}"
      }
    },
  }
}